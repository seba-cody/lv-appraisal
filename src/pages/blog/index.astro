---
import Base from '../../layouts/Base.astro';

const posts = [
  {
    title: "How Much Does a Home Appraisal Cost in Las Vegas? (2026 Guide)",
    href: "/blog/home-appraisal-cost-las-vegas",
    excerpt: "Residential appraisal fees in the Las Vegas Valley generally range from $425 to $700 for a standard single-family home. Here's what affects the price.",
    date: "2026-04-01",
  },
  {
    title: "Should You Get a Home Appraisal Before Listing in Las Vegas?",
    href: "/blog/pre-listing-appraisal-las-vegas",
    excerpt: "A pre-listing appraisal might be the most valuable $500 you spend before going to market. Here's why correctly priced homes sell faster.",
    date: "2026-04-01",
  },
  {
    title: "What to Expect During a Home Appraisal in Las Vegas",
    href: "/blog/what-to-expect-home-appraisal",
    excerpt: "A step-by-step overview of the appraisal process — from scheduling to report delivery — so you know exactly what happens at each stage.",
    date: "2026-04-01",
  },
  {
    title: "Home Appraisals for Divorce in Nevada: What You Need to Know",
    href: "/blog/divorce-appraisal-nevada",
    excerpt: "Nevada is a community property state. Here's how certified appraisals work in divorce proceedings and why online estimates don't hold up in court.",
    date: "2026-04-01",
  },
];
---

<Base
  title="Blog | Las Vegas Appraisal Co."
  description="Expert insights on home appraisals in Las Vegas — pricing, process, divorce appraisals, pre-listing tips, and more from Las Vegas Appraisal Co."
  canonical="https://lvappraisalco.com/blog"
>

  <section style="background: var(--bg-warm); padding: 80px 24px;">
    <div class="narrow" style="text-align: center;">
      <p style="font-size: 0.85rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--blue); margin-bottom: 16px; font-weight: 500;">Blog</p>
      <h1>Appraisal insights for Las Vegas homeowners</h1>
      <p style="color: var(--text-secondary); margin-top: 16px; font-size: 1.05rem;">
        Practical guidance on home appraisals, pricing, and property valuation from our team of certified appraisers.
      </p>
    </div>
  </section>

  <section>
    <div class="container" style="max-width: 800px;">
      {posts.map(post => (
        <a href={post.href} style="display: block; text-decoration: none; padding: 32px 0; border-bottom: 1px solid var(--border);">
          <h2 style="font-size: 1.3rem; color: var(--text); margin-bottom: 8px; transition: color 0.2s;">{post.title}</h2>
          <p style="color: var(--text-secondary); font-size: 0.95rem; line-height: 1.6; margin-bottom: 8px;">{post.excerpt}</p>
          <span style="font-size: 0.85rem; color: var(--blue); font-weight: 500;">Read article &rarr;</span>
        </a>
      ))}
    </div>
  </section>

</Base>
